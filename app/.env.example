# Flask Application Environment Configuration
# Copy this file to .env and fill in the values for your environment

# Flask Environment (development or production)
FLASK_ENV=production

# Debug Mode (False in production, True in development)
DEBUG=False

# Secret Key for session encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Database URL
# For PostgreSQL: postgresql://user:password@host:port/dbname
# For SQLite (development only): sqlite:///mascan_attendance.db
DATABASE_URL=postgresql://user:password@localhost:5432/mascan_attendance

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Optional: CORS settings
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
